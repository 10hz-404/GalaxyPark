{
  "buildCommand": "pnpm build",
  "headers": [
    {
      "source": "/photos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/content/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/24ef9d194f073a60d27e4308f082dbbc.txt",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"24ef9d194f073a60d27e4308f082dbbc.txt\""
        }
      ]
    }
  ]
}